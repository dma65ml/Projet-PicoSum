# Copiez ce fichier en .env et remplacez les valeurs.
# IMPORTANT : Ne jamais commiter .env dans le dépôt git.
# Générer un token sécurisé : openssl rand -hex 32

# Token Bearer partagé entre web-app et api-service (OBLIGATOIRE en production)
API_TOKEN=changez-moi-en-production

# Niveau de log : debug | info | error
LOG_LEVEL=info

# Header IP derrière un reverse proxy (laisser vide si accès direct)
# Valeur typique derrière Nginx/Traefik : X-Real-IP
# ATTENTION : n'activer que si le proxy est de confiance (sinon risque de spoofing)
TRUSTED_PROXY_HEADER=
